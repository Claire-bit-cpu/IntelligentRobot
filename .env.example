# ============================================================
# 智能机器人 - 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env：copy .env.example .env
#   2. 填写下面的配置项（必填项必须填写）
#   3. 运行 start.bat 启动服务
# ============================================================

# ============================================================
# 【必填】飞书配置
# ============================================================
# 飞书应用 ID（在飞书开放平台 → 应用管理 → 凭证与基础信息 中获取）
FEISHU_APP_ID=your_app_id_here

# 飞书应用密钥（同上）
FEISHU_APP_SECRET=your_app_secret_here

# 飞书加密密钥（可选，启用消息加密时需要）
# 在飞书开放平台 → 应用管理 → 凭证与基础信息 → 重置 Encrypt Key
FEISHU_ENCRYPT_KEY=your_encrypt_key_here

# 飞书审批定义 Code（可选，使用审批功能时需要）
# 在飞书开放平台 → 审批 → 对应审批流的「定义Code」
FEISHU_APPROVAL_DEFINITION_CODE=


# ============================================================
# 【必填】Redis 配置
# ============================================================
# Redis 主机地址（默认 localhost）
REDIS_HOST=localhost

# Redis 端口（默认 6379）
REDIS_PORT=6379

# Redis 密码（如无密码留空）
REDIS_PASSWORD=

# Redis 数据库编号（默认 0）
REDIS_DATABASE=0

# Redis 连接超时时间（毫秒，默认 5000）
REDIS_TIMEOUT=5000


# ============================================================
# 【可选】AI 配置（启用代码审查时需要）
# ============================================================
# 通义千问 API Key（在阿里云 DashScope 控制台获取）
QIANWEN_API_KEY=your_qianwen_api_key_here

# 通义千问模型（默认 qwen-turbo）
QIANWEN_MODEL=qwen-turbo

# 代码审查时的最大 diff 长度（默认 8000 字符）
QIANWEN_MAX_DIFF_LENGTH=8000


# ============================================================
# 【可选】GitHub 配置（启用 Git 集成时需要）
# ============================================================
# GitHub 个人访问令牌（在 GitHub → Settings → Developer settings → Personal access tokens 创建）
GITHUB_TOKEN=your_github_token_here

# GitHub Webhook 密钥（在 GitHub 仓库 → Settings → Webhooks → Secret 中配置）
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# 是否启用 Webhook 自动代码审查（默认 true）
GITHUB_WEBHOOK_AUTO_REVIEW=true

# 仓库别名映射（格式：别名1=owner1/repo1,别名2=owner2/repo2）
# 配置后可使用别名代替 owner/repo
GITHUB_REPO_ALIASES=frontend=owner/repo,backend=owner/repo

# 管理员 Open ID（逗号分隔，拥有敏感操作权限）
# 在飞书开放平台 → 组织架构 → 成员详情 → Open ID
GITHUB_ADMIN_OPEN_IDS=ou_xxx,ou_yyy

# 开发者 Open ID（逗号分隔，拥有日常开发权限）
GITHUB_DEVELOPER_OPEN_IDS=ou_aaa,ou_bbb

# 默认部署目标（当用户不指定 --target 参数时使用）
# 可选值：default, server1, server2, aliyun, aws, tencent
GITHUB_DEFAULT_TARGET=default

# GitHub Actions 回调配置（可选，用于接收部署完成通知）
# 回调 URL（GitHub Actions 工作流完成后调用的 URL）
GITHUB_CALLBACK_URL=
# 回调密钥（用于验证回调请求）
GITHUB_CALLBACK_SECRET=


# ============================================================
# 【可选】GitLab 配置（启用 GitLab 集成时需要）
# ============================================================
# GitLab API URL（默认 https://gitlab.com/api/v4）
GITLAB_API_URL=https://gitlab.com/api/v4

# GitLab 个人访问令牌
GITLAB_TOKEN=your_gitlab_token_here

# 是否启用 GitLab（默认 false）
GITLAB_ENABLED=false


# ============================================================
# 【可选】JIRA 配置（启用 JIRA 集成时需要）
# ============================================================
# JIRA 地址
JIRA_URL=https://your-domain.atlassian.net

# JIRA 用户名（邮箱）
JIRA_USERNAME=your_email_here

# JIRA API 令牌（在 Atlassian 账户设置中创建）
JIRA_API_TOKEN=your_api_token_here

# 是否启用 JIRA（默认 false）
JIRA_ENABLED=false

# 本地降级模式：当无法连接 JIRA 云服务时，任务记录到此文件
JIRA_LOCAL_FALLBACK_FILE=./local_tasks.md


# ============================================================
# 【可选】高德天气 API（启用天气查询时需要）
# ============================================================
# 高德地图 API Key（在高德开放平台申请）
AMAP_KEY=your_amap_api_key_here


# ============================================================
# 【可选】通知配置（智能降噪）
# ============================================================
# 通知数据库路径（默认 ./notification.db）
NOTIFICATION_DB_PATH=./notification.db

# 默认通知群聊 ID（逗号分隔，当数据库无配置时使用）
NOTIFICATION_DEFAULT_CHAT_IDS=oc_xxx,oc_yyy

# 是否启用智能降噪（去重 + 合并，默认 true）
NOTIFICATION_NOISE_REDUCTION_ENABLED=true

# 去重窗口时间（秒，默认 300 秒 = 5 分钟）
# 同一 (chatId + eventType + 内容哈希) 在窗口内只推送一次
NOTIFICATION_DEDUP_WINDOW_SECONDS=300

# 是否启用消息合并（默认 true）
NOTIFICATION_BATCH_ENABLED=true

# 合并窗口时间（秒，默认 43200 秒 = 12 小时）
# 窗口内的同类消息会被合并为一条摘要推送
NOTIFICATION_BATCH_WINDOW_SECONDS=43200

# 合并阈值（默认 0，禁用立即推送）
# 设置为 0 时，只按窗口时间定时推送（12小时）
# 设置为 5 时，达到 5 条消息立即推送合并摘要
NOTIFICATION_BATCH_THRESHOLD=0


# ============================================================
# 【可选】搜索引擎配置（SQLite FTS5）
# ============================================================
# 搜索索引数据库路径（默认 ./search-index.db）
SEARCH_INDEX_PATH=./search-index.db

# 全量同步间隔（毫秒，默认 7200000 = 2 小时）
SEARCH_SYNC_INTERVAL_MS=7200000

# 每个群聊最多同步消息数（默认 500）
SEARCH_MAX_SYNC_MESSAGES=500

# 启动后延迟执行首次同步（毫秒，默认 60000 = 60 秒）
SEARCH_STARTUP_DELAY_MS=60000

# API 调用延迟（毫秒，避免频繁调用 API，默认 100）
SEARCH_API_CALL_DELAY_MS=100

# 指定同步的群聊 ID 列表（留空则不同步任何群聊，auto 表示自动检测）
SEARCH_SYNC_CHAT_IDS=auto

# 指定同步的知识库空间 ID 列表（留空则不同步任何知识库，auto 表示自动检测）
SEARCH_SYNC_WIKI_SPACE_IDS=auto


# ============================================================
# 【可选】新成员入群欢迎配置
# ============================================================
# 是否启用欢迎消息（默认 true）
WELCOME_ENABLED=true

# 批量入群时合并发送的最小人数（默认 2）
WELCOME_BATCH_THRESHOLD=2

# 同一群聊两次欢迎的最小间隔（毫秒，默认 30000 = 30 秒）
WELCOME_COOLDOWN_MS=30000

# 批量合并窗口（毫秒，默认 3000 = 3 秒）
# 在此时间窗口内的入群成员合并为一条消息
WELCOME_BATCH_WINDOW_MS=3000


# ============================================================
# 【可选】AI 智能理解配置
# ============================================================
# 是否启用 AI 智能理解（默认 true）
# 启用后，@机器人 且非 / 开头的消息会通过 AI 理解意图
AI_ENABLED=true

# 系统提示词（可选，用于定制 AI 理解行为）
AI_SYSTEM_PROMPT=


# ============================================================
# 【可选】上下文管理器配置
# ============================================================
# 全局参数 TTL（分钟，默认 5）
# 用户无活动后自动清理上下文
CONTEXT_GLOBAL_PARAM_TTL_MINUTES=5


# ============================================================
# 【可选】敏感操作二次确认配置
# ============================================================
# 确认令牌过期时间（秒，默认 300 = 5 分钟）
CONFIRM_TOKEN_EXPIRE_SECONDS=300


# ============================================================
# 【可选】任务状态存储配置
# ============================================================
# 存储方式：memory（内存，单机）/ redis（Redis，集群）
TASK_STATUS_STORE=memory

# 单任务日志最大长度（字符，默认 5000）
# 超过此长度会截断
TASK_STATUS_MAX_LOGS_LENGTH=5000

# 慢任务阈值（毫秒，默认 3000 = 3 秒）
# 超过此耗时的任务才推送开始/完成通知
TASK_SLOW_THRESHOLD_MS=3000

# 监控卡片推送的飞书群聊 ID（留空则不推送）
TASK_MONITOR_CHAT_ID=

# 推送间隔（毫秒，默认 10000 = 10 秒）
TASK_MONITOR_PUSH_INTERVAL_MS=10000

# 是否启用自动清理（默认 true）
TASK_CLEANUP_ENABLED=true

# 清理 Cron 表达式（默认每 5 分钟）
TASK_CLEANUP_CRON=0 0/5 * * * *

# 清理超过 N 分钟的已完成/失败任务（默认 60 分钟）
TASK_CLEANUP_OLDER_THAN_MINUTES=60


# ============================================================
# 【可选】模糊匹配配置（三级响应策略 - Level 2）
# ============================================================
# 是否启用模糊匹配（默认 true）
# 输入错误时自动提示相似指令（相似度 ≥ 阈值）
FUZZY_MATCH_ENABLED=true

# 相似度阈值 [0.0, 1.0]（默认 0.70）
# >= 此值且 < 1.0 时触发"您是不是想说 /xxx？"提示
# 推荐范围：0.60（宽松）~ 0.80（严格）
FUZZY_MATCH_THRESHOLD=0.70

# 最多返回几个建议指令（默认 3）
FUZZY_MATCH_MAX_SUGGESTIONS=3


# ============================================================
# 【可选】DevOps 配置
# ============================================================
# Ping 超时时间（毫秒，默认 5000）
DEVOPS_PING_TIMEOUT_MS=5000

# HTTP 超时时间（毫秒，默认 5000）
DEVOPS_HTTP_TIMEOUT_MS=5000


# ============================================================
# 【可选】Prometheus 配置
# ============================================================
# Prometheus URL（默认 http://localhost:9090）
PROMETHEUS_URL=http://localhost:9090

# 是否启用 Prometheus（默认 false）
PROMETHEUS_ENABLED=false


# ============================================================
# 【可选】Grafana 配置
# ============================================================
# Grafana URL（默认 http://localhost:3000）
GRAFANA_URL=http://localhost:3000

# Grafana API Key
GRAFANA_API_KEY=your_grafana_api_key_here

# 是否启用 Grafana（默认 false）
GRAFANA_ENABLED=false


# ============================================================
# 【可选】限流配置
# ============================================================
# 全局 QPS 限制（默认 1000）
RATELIMIT_GLOBAL_QPS=1000

# IP 级别 QPS 限制（默认 100）
RATELIMIT_IP_QPS=100

# 是否启用限流（默认 true）
RATELIMIT_ENABLED=true


# ============================================================
# 【可选】线程池配置（高并发优化）
# ============================================================
# 高优先级线程池 - 核心线程数（默认 10）
THREAD_POOL_HIGH_CORE_SIZE=10

# 高优先级线程池 - 最大线程数（默认 50）
THREAD_POOL_HIGH_MAX_SIZE=50

# 高优先级线程池 - 队列容量（默认 1000）
THREAD_POOL_HIGH_QUEUE_CAPACITY=1000

# 低优先级线程池 - 核心线程数（默认 5）
THREAD_POOL_LOW_CORE_SIZE=5

# 低优先级线程池 - 最大线程数（默认 20）
THREAD_POOL_LOW_MAX_SIZE=20

# 低优先级线程池 - 队列容量（默认 2000）
THREAD_POOL_LOW_QUEUE_CAPACITY=2000


# ============================================================
# 【可选】消息去重配置
# ============================================================
# 去重窗口时间（毫秒，默认 30000 = 30 秒）
DEDUP_WINDOW_MS=30000

# 去重清理时间（毫秒，默认 600000 = 10 分钟）
DEDUP_CLEANUP_MS=600000


# ============================================================
# 【可选】服务器配置
# ============================================================
# 服务端口（默认 8082）
SERVER_PORT=8082
